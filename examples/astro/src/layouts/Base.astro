---
export interface Props {
  title: string;
}
const { title } = Astro.props;

// import.meta.env.BASE_URL is '/' locally and '/component-anatomy/' on GitHub Pages.
// Using it as a prefix makes all internal links work in both environments.
const base = import.meta.env.BASE_URL;
const path = Astro.url.pathname;
---
<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{title} — Component Anatomy</title>
    <!-- Bootstrap v5 (used by Bootstrap example pages) -->
    <link
      rel="stylesheet"
      href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css"
      crossorigin="anonymous"
    />
    <style>
      *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

      body {
        font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', sans-serif;
        background: #fff;
        color: #111827;
        line-height: 1.6;
      }

      .site-header {
        border-bottom: 1px solid #e5e7eb;
        padding: 0 2rem;
        display: flex;
        align-items: center;
        height: 56px;
        gap: 2rem;
      }

      .site-logo {
        font-size: 0.85rem;
        font-weight: 700;
        letter-spacing: 0.03em;
        color: #111;
        text-decoration: none;
      }

      .site-nav {
        display: flex;
        gap: 1.5rem;
      }

      .site-nav a {
        font-size: 0.875rem;
        color: #6b7280;
        text-decoration: none;
      }

      .site-nav-sep { color: #d1d5db; }

      .site-nav a:hover,
      .site-nav a[aria-current="page"] {
        color: #111;
      }

      .page {
        max-width: 960px;
        margin: 0 auto;
        padding: 3rem 2rem;
      }

      .page-title {
        font-size: 1.5rem;
        font-weight: 700;
        margin-bottom: 0.4rem;
      }

      .page-subtitle {
        font-size: 0.9rem;
        color: #6b7280;
        margin-bottom: 2.5rem;
      }

      .section {
        margin-bottom: 4rem;
      }

      .section-label {
        font-size: 0.7rem;
        font-weight: 600;
        text-transform: uppercase;
        letter-spacing: 0.1em;
        color: #9ca3af;
        margin-bottom: 1.5rem;
        padding-bottom: 0.5rem;
        border-bottom: 1px solid #f3f4f6;
      }
    </style>
  </head>
  <body>
    <header class="site-header">
      <a href={base} class="site-logo">Component Anatomy</a>
      <nav class="site-nav">
        <a href={`${base}button`}   aria-current={path === `${base}button`   ? 'page' : undefined}>Button</a>
        <a href={`${base}slider`}   aria-current={path === `${base}slider`   ? 'page' : undefined}>Slider</a>
        <span class="site-nav-sep">·</span>
        <a href={`${base}bs-button`} aria-current={path === `${base}bs-button` ? 'page' : undefined}>BS Button</a>
        <a href={`${base}bs-alert`}  aria-current={path === `${base}bs-alert`  ? 'page' : undefined}>BS Alert</a>
        <a href={`${base}bs-card`}   aria-current={path === `${base}bs-card`   ? 'page' : undefined}>BS Card</a>
        <a href={`${base}bs-badge`}  aria-current={path === `${base}bs-badge`  ? 'page' : undefined}>BS Badge</a>
        <a href={`${base}bs-navbar`} aria-current={path === `${base}bs-navbar` ? 'page' : undefined}>BS Navbar</a>
      </nav>
    </header>

    <main class="page">
      <slot />
    </main>
  </body>
</html>
