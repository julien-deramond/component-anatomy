---
export interface Props {
  title: string;
}
const { title } = Astro.props;
---
<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{title} — Component Anatomy</title>
    <style>
      *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

      body {
        font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', sans-serif;
        background: #fff;
        color: #111827;
        line-height: 1.6;
      }

      .site-header {
        border-bottom: 1px solid #e5e7eb;
        padding: 0 2rem;
        display: flex;
        align-items: center;
        height: 56px;
        gap: 2rem;
      }

      .site-logo {
        font-size: 0.85rem;
        font-weight: 700;
        letter-spacing: 0.03em;
        color: #111;
        text-decoration: none;
      }

      .site-nav {
        display: flex;
        gap: 1.5rem;
      }

      .site-nav a {
        font-size: 0.875rem;
        color: #6b7280;
        text-decoration: none;
      }

      .site-nav a:hover,
      .site-nav a[aria-current="page"] {
        color: #111;
      }

      .page {
        max-width: 960px;
        margin: 0 auto;
        padding: 3rem 2rem;
      }

      .page-title {
        font-size: 1.5rem;
        font-weight: 700;
        margin-bottom: 0.4rem;
      }

      .page-subtitle {
        font-size: 0.9rem;
        color: #6b7280;
        margin-bottom: 2.5rem;
      }

      .section {
        margin-bottom: 4rem;
      }

      .section-label {
        font-size: 0.7rem;
        font-weight: 600;
        text-transform: uppercase;
        letter-spacing: 0.1em;
        color: #9ca3af;
        margin-bottom: 1.5rem;
        padding-bottom: 0.5rem;
        border-bottom: 1px solid #f3f4f6;
      }
    </style>
  </head>
  <body>
    <header class="site-header">
      <a href="/" class="site-logo">Component Anatomy</a>
      <nav class="site-nav">
        <a href="/button" aria-current={Astro.url.pathname === '/button' ? 'page' : undefined}>Button</a>
        <a href="/slider" aria-current={Astro.url.pathname === '/slider' ? 'page' : undefined}>Slider</a>
      </nav>
    </header>

    <main class="page">
      <slot />
    </main>
  </body>
</html>
