---
import Base from '../layouts/Base.astro';
import ComponentAnatomy from '@component-anatomy/astro/ComponentAnatomy.astro';
import Slider from '../components/Slider.astro';
import type { AnatomyPartDefinition } from '@component-anatomy/core';

const base = import.meta.env.BASE_URL.replace(/\/?$/, '/');
const GITHUB = 'https://github.com/julien-deramond/component-anatomy';

const sliderParts: AnatomyPartDefinition[] = [
  { id: 'root', name: 'Root', description: 'The component wrapper — groups every part below.' },
  { id: 'track', name: 'Track', description: 'The rail the thumb travels along.' },
  { id: 'range', name: 'Range', description: 'The filled portion, visualizing the current value.' },
  { id: 'thumb', name: 'Thumb', description: 'The draggable handle. Focusable, arrow-key operable.' },
  { id: 'output', name: 'Output', description: 'Live value readout, announced via `aria-live`.' },
];

const features = [
  {
    icon: 'M12 2v4m0 12v4M2 12h4m12 0h4',
    title: 'Framework-agnostic core',
    desc: 'A dependency-free ~4 kB runtime. Works in plain HTML, any bundler, any framework — anywhere a DOM exists.',
  },
  {
    icon: 'M8 3 4 7l4 4M16 21l4-4-4-4M4 7h16M20 17H4',
    title: 'Two-way hover sync',
    desc: 'Hover docs → highlight the component. Hover the component → highlight the docs. Always in sync.',
  },
  {
    icon: 'M12 3v18m9-9H3',
    title: 'One attribute',
    desc: 'Annotate elements with data-part="thumb". Parts are auto-discovered, names derived from ids.',
  },
  {
    icon: 'M12 2a7 7 0 0 0-7 7c0 2.4 1.2 4.5 3 5.7V17a2 2 0 0 0 2 2h4a2 2 0 0 0 2-2v-2.3c1.8-1.2 3-3.3 3-5.7a7 7 0 0 0-7-7z',
    title: 'Themable rendering',
    desc: 'Four presets, one-line accent theming, CSS variables, render hooks. Beautiful defaults, full control.',
  },
  {
    icon: 'M9 3H5a2 2 0 0 0-2 2v4m18 0V5a2 2 0 0 0-2-2h-4m0 18h4a2 2 0 0 0 2-2v-4M3 15v4a2 2 0 0 0 2 2h4',
    title: 'Live overlays',
    desc: 'Highlight boxes track the real rendered DOM — resize, scroll, dynamic updates included.',
  },
  {
    icon: 'M12 8V4H8m8 8h4v-4M8 16H4v4m12-4h4v4',
    title: 'Astro & Storybook',
    desc: 'A drop-in Astro component with SSR Markdown, and a Storybook addon panel for any renderer.',
  },
];

const packages = [
  {
    name: '@component-anatomy/core',
    href: 'docs/core',
    desc: 'The runtime: createAnatomy(), overlays, theming, events.',
  },
  {
    name: '@component-anatomy/astro',
    href: 'docs/astro',
    desc: 'Two-column anatomy block with SSR Markdown descriptions.',
  },
  {
    name: '@component-anatomy/storybook',
    href: 'docs/storybook',
    desc: 'An "Anatomy" panel synced with the story canvas. SB 9/10.',
  },
];
---
<Base title="Interactive component anatomy docs" landing>
  <div class="landing">
    <!-- ════════ Hero ════════ -->
    <header class="hero">
      <nav class="hero-nav">
        <a href={base} class="hero-logo">
          <span class="hero-logo-mark" aria-hidden="true">
            <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.4" stroke-linecap="round">
              <path d="M8 3H5a2 2 0 0 0-2 2v3m18 0V5a2 2 0 0 0-2-2h-3m0 18h3a2 2 0 0 0 2-2v-3M3 16v3a2 2 0 0 0 2 2h3"/>
              <circle cx="12" cy="12" r="3.2"/>
            </svg>
          </span>
          Component Anatomy
        </a>
        <div class="hero-nav-links">
          <a href={`${base}docs/core`}>Docs</a>
          <a href={`${base}theming`}>Demos</a>
          <a href={`${base}storybook/`}>Storybook</a>
          <a href={GITHUB} target="_blank" rel="noopener" class="hero-nav-gh" aria-label="GitHub">
            <svg width="17" height="17" viewBox="0 0 16 16" fill="currentColor"><path d="M8 0C3.58 0 0 3.58 0 8c0 3.54 2.29 6.53 5.47 7.59.4.07.55-.17.55-.38 0-.19-.01-.82-.01-1.49-2.01.37-2.53-.49-2.69-.94-.09-.23-.48-.94-.82-1.13-.28-.15-.68-.52-.01-.53.63-.01 1.08.58 1.23.82.72 1.21 1.87.87 2.33.66.07-.52.28-.87.51-1.07-1.78-.2-3.64-.89-3.64-3.95 0-.87.31-1.59.82-2.15-.08-.2-.36-1.02.08-2.12 0 0 .67-.21 2.2.82.64-.18 1.32-.27 2-.27s1.36.09 2 .27c1.53-1.04 2.2-.82 2.2-.82.44 1.1.16 1.92.08 2.12.51.56.82 1.27.82 2.15 0 3.07-1.87 3.75-3.65 3.95.29.25.54.73.54 1.48 0 1.07-.01 1.93-.01 2.2 0 .21.15.46.55.38A8.01 8.01 0 0 0 16 8c0-4.42-3.58-8-8-8Z"/></svg>
          </a>
        </div>
      </nav>

      <div class="hero-body">
        <p class="hero-badge">
          <span class="hero-badge-dot"></span>
          v0.1 · MIT · Framework-agnostic
        </p>
        <h1 class="hero-title">
          Component anatomy docs<br />
          <span class="hero-title-accent">that are actually alive</span>
        </h1>
        <p class="hero-sub">
          Stop exporting annotated screenshots from Figma. Annotate your rendered
          DOM with <code>data-part</code> and get an interactive, synchronized
          anatomy panel — in plain HTML, Astro, or Storybook.
        </p>
        <div class="hero-ctas">
          <a href={`${base}docs/core`} class="cta cta-primary">
            Get started
            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14m-6-6 6 6-6 6"/></svg>
          </a>
          <a href={GITHUB} target="_blank" rel="noopener" class="cta cta-ghost">
            <svg width="15" height="15" viewBox="0 0 16 16" fill="currentColor"><path d="M8 0C3.58 0 0 3.58 0 8c0 3.54 2.29 6.53 5.47 7.59.4.07.55-.17.55-.38 0-.19-.01-.82-.01-1.49-2.01.37-2.53-.49-2.69-.94-.09-.23-.48-.94-.82-1.13-.28-.15-.68-.52-.01-.53.63-.01 1.08.58 1.23.82.72 1.21 1.87.87 2.33.66.07-.52.28-.87.51-1.07-1.78-.2-3.64-.89-3.64-3.95 0-.87.31-1.59.82-2.15-.08-.2-.36-1.02.08-2.12 0 0 .67-.21 2.2.82.64-.18 1.32-.27 2-.27s1.36.09 2 .27c1.53-1.04 2.2-.82 2.2-.82.44 1.1.16 1.92.08 2.12.51.56.82 1.27.82 2.15 0 3.07-1.87 3.75-3.65 3.95.29.25.54.73.54 1.48 0 1.07-.01 1.93-.01 2.2 0 .21.15.46.55.38A8.01 8.01 0 0 0 16 8c0-4.42-3.58-8-8-8Z"/></svg>
            Star on GitHub
          </a>
        </div>
        <pre class="hero-code"><code><span class="tk-c">// 1. Annotate your component</span>
&lt;div class="thumb" <span class="tk-a">data-part="thumb"</span>&gt;&lt;/div&gt;

<span class="tk-c">// 2. Wire it up</span>
<span class="tk-k">import</span> {'{ createAnatomy }'} <span class="tk-k">from</span> <span class="tk-s">'@component-anatomy/core'</span>;
<span class="tk-f">createAnatomy</span>({'{ root, panel }'});</code></pre>
      </div>
    </header>

    <!-- ════════ Live demo ════════ -->
    <section class="band">
      <div class="band-inner">
        <p class="band-kicker">Try it — this is real</p>
        <h2 class="band-title">Hover the docs. Hover the component.</h2>
        <p class="band-sub">
          This slider is a live component on this page, documented by the library itself.
        </p>
        <div class="demo-frame">
          <ComponentAnatomy parts={sliderParts}>
            <Slider />
          </ComponentAnatomy>
        </div>
        <p class="band-more">
          More demos:
          <a href={`${base}theming`}>presets &amp; theming</a> ·
          <a href={`${base}bs-button`}>Bootstrap via CDN</a> ·
          <a href={`${base}shadcn`}>shadcn-style</a> ·
          <a href={`${base}storybook/`}>Storybook addon ↗</a>
        </p>
      </div>
    </section>

    <!-- ════════ Features ════════ -->
    <section class="band band-alt">
      <div class="band-inner">
        <p class="band-kicker">Why</p>
        <h2 class="band-title">Small API, serious rendering</h2>
        <div class="feature-grid">
          {features.map((f) => (
            <div class="feature">
              <span class="feature-icon" aria-hidden="true">
                <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><path d={f.icon}/></svg>
              </span>
              <h3 class="feature-title">{f.title}</h3>
              <p class="feature-desc">{f.desc}</p>
            </div>
          ))}
        </div>
      </div>
    </section>

    <!-- ════════ Packages ════════ -->
    <section class="band">
      <div class="band-inner">
        <p class="band-kicker">Packages</p>
        <h2 class="band-title">Pick your entry point</h2>
        <div class="pkg-grid">
          {packages.map((p) => (
            <a class="pkg" href={`${base}${p.href}`}>
              <code class="pkg-name">{p.name}</code>
              <p class="pkg-desc">{p.desc}</p>
              <span class="pkg-link">Read the docs →</span>
            </a>
          ))}
        </div>
      </div>
    </section>

    <!-- ════════ Footer ════════ -->
    <footer class="footer">
      <div class="band-inner footer-inner">
        <p>MIT © Julien Déramond</p>
        <div class="footer-links">
          <a href={`${base}docs/core`}>Docs</a>
          <a href={`${base}docs/faq`}>FAQ</a>
          <a href={GITHUB} target="_blank" rel="noopener">GitHub</a>
          <a href="https://www.npmjs.com/package/@component-anatomy/core" target="_blank" rel="noopener">npm</a>
        </div>
      </div>
    </footer>
  </div>
</Base>

<style>
  .landing { color: var(--site-body); }

  /* ════════ Hero ════════ */
  .hero {
    position: relative;
    background:
      radial-gradient(ellipse 60% 50% at 50% -10%, rgb(99 102 241 / 0.35), transparent),
      radial-gradient(ellipse 40% 35% at 80% 10%, rgb(139 92 246 / 0.18), transparent),
      #0b1023;
    color: #e2e8f0;
    overflow: hidden;
  }
  .hero::before {
    content: '';
    position: absolute;
    inset: 0;
    background-image: radial-gradient(circle, rgb(148 163 184 / 0.14) 1px, transparent 1px);
    background-size: 26px 26px;
    mask-image: linear-gradient(to bottom, rgb(0 0 0 / 0.9), transparent 75%);
    pointer-events: none;
  }

  .hero-nav {
    position: relative;
    max-width: 1080px;
    margin: 0 auto;
    padding: 1.4rem 2rem;
    display: flex;
    align-items: center;
    justify-content: space-between;
  }
  .hero-logo {
    display: flex;
    align-items: center;
    gap: 0.6rem;
    font-size: 0.9rem;
    font-weight: 700;
    color: #f1f5f9;
    text-decoration: none;
    letter-spacing: -0.01em;
  }
  .hero-logo-mark {
    display: grid;
    place-items: center;
    width: 28px; height: 28px;
    border-radius: 8px;
    background: linear-gradient(135deg, #6366f1, #8b5cf6);
    color: #fff;
    box-shadow: 0 0 24px rgb(99 102 241 / 0.55);
  }
  .hero-nav-links {
    display: flex;
    align-items: center;
    gap: 1.6rem;
  }
  .hero-nav-links a {
    font-size: 0.84rem;
    font-weight: 500;
    color: #cbd5e1;
    text-decoration: none;
  }
  .hero-nav-links a:hover { color: #fff; }
  .hero-nav-gh { display: grid; place-items: center; }

  .hero-body {
    position: relative;
    max-width: 780px;
    margin: 0 auto;
    padding: 4.5rem 2rem 5.5rem;
    text-align: center;
  }
  .hero-badge {
    display: inline-flex;
    align-items: center;
    gap: 0.45rem;
    font-size: 0.72rem;
    font-weight: 600;
    font-family: var(--font-mono);
    letter-spacing: 0.02em;
    color: #c7d2fe;
    background: rgb(99 102 241 / 0.12);
    border: 1px solid rgb(99 102 241 / 0.35);
    border-radius: 99px;
    padding: 0.3rem 0.85rem;
    margin-bottom: 1.6rem;
  }
  .hero-badge-dot {
    width: 6px; height: 6px;
    border-radius: 50%;
    background: #818cf8;
    box-shadow: 0 0 8px #818cf8;
  }
  .hero-title {
    font-size: clamp(2rem, 5.4vw, 3.3rem);
    font-weight: 800;
    letter-spacing: -0.035em;
    line-height: 1.12;
    color: #f8fafc;
    margin-bottom: 1.2rem;
  }
  .hero-title-accent {
    background: linear-gradient(90deg, #a5b4fc, #c4b5fd, #a5b4fc);
    -webkit-background-clip: text;
    background-clip: text;
    color: transparent;
  }
  .hero-sub {
    font-size: 1.02rem;
    color: #94a3b8;
    max-width: 54ch;
    margin: 0 auto 2.2rem;
  }
  .hero-sub code {
    font-family: var(--font-mono);
    font-size: 0.85em;
    color: #c7d2fe;
    background: rgb(99 102 241 / 0.14);
    border: 1px solid rgb(99 102 241 / 0.3);
    border-radius: 5px;
    padding: 0.1em 0.4em;
  }
  .hero-ctas {
    display: flex;
    justify-content: center;
    gap: 0.8rem;
    flex-wrap: wrap;
    margin-bottom: 3.25rem;
  }
  .cta {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    font-size: 0.88rem;
    font-weight: 600;
    padding: 0.68rem 1.35rem;
    border-radius: 10px;
    text-decoration: none;
    transition: transform 120ms ease, box-shadow 120ms ease, background 120ms ease;
  }
  .cta-primary {
    background: linear-gradient(135deg, #6366f1, #7c3aed);
    color: #fff;
    box-shadow: 0 4px 24px rgb(99 102 241 / 0.45);
  }
  .cta-primary:hover { transform: translateY(-1px); box-shadow: 0 6px 32px rgb(99 102 241 / 0.6); }
  .cta-ghost {
    color: #e2e8f0;
    background: rgb(255 255 255 / 0.06);
    border: 1px solid rgb(255 255 255 / 0.14);
  }
  .cta-ghost:hover { background: rgb(255 255 255 / 0.1); }

  .hero-code {
    text-align: left;
    max-width: 560px;
    margin: 0 auto;
    background: rgb(2 6 23 / 0.75);
    border: 1px solid rgb(99 102 241 / 0.25);
    border-radius: 14px;
    padding: 1.2rem 1.5rem;
    font-family: var(--font-mono);
    font-size: 0.8rem;
    line-height: 1.75;
    color: #e2e8f0;
    box-shadow: 0 20px 60px rgb(2 6 23 / 0.55), inset 0 1px 0 rgb(255 255 255 / 0.04);
    overflow-x: auto;
    backdrop-filter: blur(6px);
  }
  .hero-code code {
    background: none;
    border: none;
    padding: 0;
    color: inherit;
    font-size: inherit;
    font-family: inherit;
  }
  .tk-c { color: #64748b; }
  .tk-a { color: #6ee7b7; }
  .tk-k { color: #c4b5fd; }
  .tk-s { color: #fca5a5; }
  .tk-f { color: #93c5fd; }

  /* ════════ Bands ════════ */
  .band { padding: 4.5rem 2rem; }
  .band-alt { background: #f8fafc; border-block: 1px solid var(--site-line-soft); }
  .band-inner { max-width: 1000px; margin: 0 auto; }
  .band-kicker {
    font-size: 0.7rem;
    font-weight: 700;
    font-family: var(--font-mono);
    text-transform: uppercase;
    letter-spacing: 0.12em;
    color: var(--site-accent);
    margin-bottom: 0.6rem;
  }
  .band-title {
    font-size: 1.55rem;
    font-weight: 800;
    letter-spacing: -0.025em;
    color: var(--site-ink);
    margin-bottom: 0.5rem;
  }
  .band-sub { font-size: 0.92rem; color: var(--site-muted); margin-bottom: 2rem; }
  .band-more { margin-top: 1.75rem; font-size: 0.85rem; color: var(--site-muted); }
  .band-more a { color: var(--site-accent); text-decoration: none; font-weight: 550; }
  .band-more a:hover { text-decoration: underline; }

  .demo-frame {
    border: 1px solid var(--site-line);
    border-radius: 16px;
    padding: 2rem;
    box-shadow: 0 8px 40px rgb(15 23 42 / 0.06);
    background: #fff;
  }

  /* ════════ Features ════════ */
  .feature-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(280px, 1fr));
    gap: 1rem;
    margin-top: 2rem;
  }
  .feature {
    background: #fff;
    border: 1px solid var(--site-line);
    border-radius: 14px;
    padding: 1.4rem 1.4rem 1.3rem;
    transition: border-color 150ms ease, box-shadow 150ms ease, transform 150ms ease;
  }
  .feature:hover {
    border-color: #c7d2fe;
    box-shadow: 0 8px 30px rgb(99 102 241 / 0.1);
    transform: translateY(-2px);
  }
  .feature-icon {
    display: grid;
    place-items: center;
    width: 36px; height: 36px;
    border-radius: 10px;
    background: var(--site-accent-soft);
    color: var(--site-accent);
    margin-bottom: 0.9rem;
  }
  .feature-title { font-size: 0.92rem; font-weight: 700; color: var(--site-ink); margin-bottom: 0.35rem; }
  .feature-desc { font-size: 0.83rem; color: var(--site-muted); }
  .feature-desc code, .feature-desc { font-family: inherit; }

  /* ════════ Packages ════════ */
  .pkg-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(280px, 1fr));
    gap: 1rem;
    margin-top: 2rem;
  }
  .pkg {
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
    background: #fff;
    border: 1px solid var(--site-line);
    border-radius: 14px;
    padding: 1.4rem;
    text-decoration: none;
    transition: border-color 150ms ease, box-shadow 150ms ease, transform 150ms ease;
  }
  .pkg:hover {
    border-color: #c7d2fe;
    box-shadow: 0 8px 30px rgb(99 102 241 / 0.1);
    transform: translateY(-2px);
  }
  .pkg-name {
    font-family: var(--font-mono);
    font-size: 0.78rem;
    font-weight: 600;
    color: #3730a3;
    background: var(--site-accent-soft);
    border: 1px solid #e0e7ff;
    border-radius: 6px;
    padding: 0.25rem 0.5rem;
    align-self: flex-start;
  }
  .pkg-desc { font-size: 0.83rem; color: var(--site-muted); flex: 1; }
  .pkg-link { font-size: 0.8rem; font-weight: 600; color: var(--site-accent); }

  /* ════════ Footer ════════ */
  .footer {
    border-top: 1px solid var(--site-line-soft);
    padding: 1.8rem 2rem;
  }
  .footer-inner {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 1rem;
    flex-wrap: wrap;
    font-size: 0.8rem;
    color: var(--site-faint);
  }
  .footer-links { display: flex; gap: 1.4rem; }
  .footer-links a { color: var(--site-muted); text-decoration: none; font-weight: 500; }
  .footer-links a:hover { color: var(--site-ink); }
</style>
