{
  "name": "@component-anatomy/core",
  "version": "0.0.1",
  "description": "Framework-agnostic runtime for interactive component anatomy documentation",
  "license": "MIT",
  "author": "Julien Déramond",
  "homepage": "https://github.com/julien-deramond/component-anatomy#readme",
  "repository": {
    "type": "git",
    "url": "https://github.com/julien-deramond/component-anatomy",
    "directory": "packages/core"
  },
  "bugs": {
    "url": "https://github.com/julien-deramond/component-anatomy/issues"
  },
  "keywords": [
    "component-anatomy",
    "design-system",
    "documentation",
    "dom",
    "overlay",
    "anatomy",
    "interactive",
    "framework-agnostic"
  ],
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    },
    "./package.json": "./package.json"
  },
  "files": [
    "dist",
    "src"
  ],
  "publishConfig": {
    "access": "public"
  },
  "sideEffects": false,
  "scripts": {
    "build": "node build.mjs",
    "typecheck": "tsc --noEmit",
    "test": "vitest run"
  },
  "devDependencies": {
    "esbuild": "^0.28.1",
    "typescript": "^7.0.2",
    "vitest": "^4.1.9",
    "jsdom": "^29.1.1"
  },
  "engines": {
    "node": ">=22.12.0"
  }
}
