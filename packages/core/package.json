  },
  "files": ["dist"],
  "scripts": {
    "build": "node build.mjs",
    "dev": "node build.mjs",
    "typecheck": "tsc --noEmit"
  },
  "devDependencies": {
    "tsup": "^8.3.0",
    "typescript": "^5.4.5"
  }
}
