  },
  "dependencies": {
    "@component-anatomy/core": "workspace:^",
    "marked": "^18.0.5"
  },
  "devDependencies": {
    "astro": "^7.0.6",
    "typescript": "^7.0.2"
  },
  "peerDependencies": {
    "astro": ">=7.0.0"
  },
  "engines": {
    "node": ">=22.12.0"
