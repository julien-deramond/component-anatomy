{
  "name": "component-anatomy-monorepo",
  "private": true,
  "version": "0.0.0",
  "description": "Monorepo for the component-anatomy library",
  "license": "MIT",
  "author": "Julien Déramond",
  "repository": {
    "type": "git",
    "url": "https://github.com/julien-deramond/component-anatomy"
  },
  "packageManager": "pnpm@9.15.9",
  "scripts": {
    "build": "pnpm --filter @component-anatomy/core build",
    "build:packages": "pnpm --filter @component-anatomy/core build && pnpm --filter @component-anatomy/astro build",
    "dev": "pnpm --filter examples-astro dev",
    "typecheck": "pnpm --filter @component-anatomy/core typecheck",
    "changeset": "changeset",
    "version": "changeset version",
    "release": "pnpm run build:packages && changeset publish"
  },
  "devDependencies": {
    "@changesets/changelog-github": "^0.7.0",
    "@changesets/cli": "^2.31.0",
    "typescript": "^5.4.5"
  },
  "engines": {
    "node": ">=18.0.0",
    "pnpm": ">=9.0.0"
  }
}
