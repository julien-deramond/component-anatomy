{
  "name": "component-anatomy-monorepo",
  "private": true,
  "version": "0.0.0",
  "description": "Monorepo for the component-anatomy library",
  "license": "MIT",
  "author": "Julien Déramond",
  "repository": {
    "type": "git",
    "url": "https://github.com/julien-deramond/component-anatomy"
  },
  "packageManager": "pnpm@9.15.9+sha512.68046141893c66fad01c079231128e9afb89ef87e2691d69e4d40eee228988295fd4682181bae55b58418c3a253bde65a505ec7c5f9403ece5cc3cd37dcf2531",
  "scripts": {
    "build": "pnpm --filter @component-anatomy/core build",
    "build:packages": "pnpm --filter @component-anatomy/core build && pnpm --filter @component-anatomy/astro build && pnpm --filter @component-anatomy/storybook build",
    "dev": "pnpm --filter examples-astro dev",
    "typecheck": "pnpm --filter @component-anatomy/core typecheck && pnpm --filter @component-anatomy/storybook typecheck",
    "changeset": "changeset",
    "version": "changeset version",
    "release": "pnpm run build:packages && changeset publish",
    "test": "pnpm --filter @component-anatomy/core test"
  },
  "devDependencies": {
    "@changesets/changelog-github": "^0.7.0",
    "@changesets/cli": "^2.31.0",
    "typescript": "^6.0.3"
  },
  "engines": {
    "node": ">=18.0.0",
    "pnpm": ">=9.0.0"
  }
}
